---
const rows = [
  { feature: 'Isolation model', docker: 'Namespaces (kernel shared)', ignite: 'KVM (own kernel per VM)', winner: 'ignite' },
  { feature: 'Cold start', docker: '~500ms', ignite: '<150ms', winner: 'ignite' },
  { feature: 'Memory overhead', docker: '~2MB', ignite: '~5MB', winner: 'docker' },
  { feature: 'Image format', docker: 'OCI', ignite: 'OCI (same images)', winner: 'tie' },
  { feature: 'CLI familiarity', docker: 'docker run/ps/stop', ignite: 'ign run/ps/stop (superset)', winner: 'ignite' },
  { feature: 'Hardware snapshots', docker: '❌ Not possible', ignite: '✅ CPU + RAM + disk', winner: 'ignite' },
  { feature: 'Live migration', docker: '❌ Not possible', ignite: '✅ 20-80ms downtime', winner: 'ignite' },
  { feature: 'Time travel / branching', docker: '❌ Not possible', ignite: '✅ Git-like history', winner: 'ignite' },
  { feature: 'Hibernate to zero', docker: '❌ Loses state', ignite: '✅ Full state preserved', winner: 'ignite' },
  { feature: 'Kernel customization', docker: '❌ Host kernel', ignite: '✅ Per-VM kernel', winner: 'ignite' },
  { feature: 'Security layers', docker: '2–3', ignite: '7 independent layers', winner: 'ignite' },
  { feature: 'Compose support', docker: 'docker-compose.yml', ignite: 'Same file, vm: extensions', winner: 'tie' },
];
---

<section class="sec sec--border">
  <div class="wrap">
    <div style="text-align:center;display:flex;flex-direction:column;align-items:center">
      <p class="label">Comparison</p>
      <h2 class="heading--sm" style="margin-top:0.75rem">
        Docker vs Ignite.<br/><span class="grad">Honest comparison.</span>
      </h2>
      <p class="subheading" style="margin-top:1rem;text-align:center">
        Ignite isn't replacing containers for everything. It's for when isolation actually matters.
      </p>
    </div>

    <div class="cmp__table-wrap">
      <table class="cmp__table">
        <thead>
          <tr>
            <th>Feature</th>
            <th>Docker</th>
            <th class="cmp__th-ign">Ignite 🔥</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr>
              <td class="cmp__feature">{r.feature}</td>
              <td class={r.winner === 'docker' ? 'cmp__win' : ''}>{r.docker}</td>
              <td class={r.winner === 'ignite' ? 'cmp__win cmp__ign' : 'cmp__ign'}>{r.ignite}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
.cmp__table-wrap{
  margin-top:3rem;overflow-x:auto;
  border:1px solid var(--border);border-radius:var(--radius-lg);
}
.cmp__table{
  width:100%;border-collapse:collapse;font-size:0.875rem;
}
.cmp__table th{
  padding:1rem 1.25rem;text-align:left;font-weight:700;font-size:0.8125rem;
  background:var(--bg-card);border-bottom:1px solid var(--border);color:var(--text-dim);
}
.cmp__th-ign{color:var(--fire-light) !important}
.cmp__table td{
  padding:0.8rem 1.25rem;border-bottom:1px solid var(--border);color:var(--text-dim);
}
.cmp__table tr:last-child td{border-bottom:none}
.cmp__table tr:hover td{background:var(--bg-card)}
.cmp__feature{font-weight:600;color:var(--text)}
.cmp__win{font-weight:600}
.cmp__ign{color:var(--text)}
td.cmp__win.cmp__ign{color:var(--green);font-weight:600}
td.cmp__win:not(.cmp__ign){color:var(--green)}
</style>
