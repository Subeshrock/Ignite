<section class="hero">
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="hero__grid" aria-hidden="true"></div>
  <div class="hero__particles" aria-hidden="true">
    <div class="particle p1"></div>
    <div class="particle p2"></div>
    <div class="particle p3"></div>
  </div>

  <div class="wrap hero__wrap">
    <div class="tag tag--fire">
      <span>🔥</span> Now in v1.1 — Open Source · Apache 2.0
    </div>

    <h1 class="hero__h1">
      Run VMs like containers.<br />
      <span class="grad">Isolated like nothing else.</span>
    </h1>

    <p class="hero__sub">
      Ignite is a MicroVM manager powered by Firecracker. Use Docker images you
      already have, get <strong>hardware-level isolation</strong> in under 150ms.
      One binary. No YAML gymnastics.
    </p>

    <div class="hero__install">
      <div class="hero__cmd">
        <span class="hero__prompt">$</span>
        <span>curl -sfL https://get.ignite.dev | sh</span>
        <button
          class="hero__copy"
          aria-label="Copy"
          onclick="navigator.clipboard.writeText('curl -sfL https://get.ignite.dev | sh')"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><rect x="9" y="9" width="13" height="13" rx="2"></rect><path
              d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"
            ></path></svg
          >
        </button>
      </div>
    </div>

    <div class="hero__actions">
      <a href="#start" class="btn btn--fire">Get Started →</a>
      <a
        href="https://github.com/Subeshrock/micro-vm-ecosystem.git"
        target="_blank"
        rel="noopener"
        class="btn btn--ghost">View on GitHub ↗</a
      >
    </div>

    <div class="hero__stats">
      <div class="hero__stat">
        <strong>&lt;150ms</strong>
        <span>Cold boot</span>
      </div>
      <div class="hero__stat-sep" aria-hidden="true"></div>
      <div class="hero__stat">
        <strong>~5 MB</strong>
        <span>VM overhead</span>
      </div>
      <div class="hero__stat-sep" aria-hidden="true"></div>
      <div class="hero__stat">
        <strong>100%</strong>
        <span>Kernel isolation</span>
      </div>
      <div class="hero__stat-sep" aria-hidden="true"></div>
      <div class="hero__stat">
        <strong>0</strong>
        <span>Config files needed</span>
      </div>
    </div>

    <!-- Terminal demo -->
    <div class="hero__terminal">
      <div class="term__bar">
        <div class="term__dots"><span></span><span></span><span></span></div>
        <span class="term__title">terminal</span>
      </div>
      <div class="term__body codeblock">
        <span class="c"># Boot an Ubuntu MicroVM in &lt;150ms</span><br />
        <span class="k">$ ign run</span>
        <span class="s">ubuntu:latest</span>
        <span class="f">--vcpu 2 --memory 512M -p 8080:80</span><br />
        <span class="c">⚡ VM booted in 127ms — 172.19.0.2</span><br /><br />

        <span class="c"># It's a real VM with its own kernel</span><br />
        <span class="k">$ ign exec</span>
        <span class="s">my-vm</span>
        <span class="f">uname -a</span><br />
        <span class="c"
          >Linux ignite-vm 5.10.0-ignite #1 SMP x86_64 GNU/Linux</span
        ><br /><br />

        <span class="c"># Snapshot the entire machine state</span><br />
        <span class="k">$ ign snapshot</span>
        <span class="s">my-vm</span>
        <span class="f">--name before-deploy</span><br />
        <span class="c"
          >📸 Snapshot saved: CPU + RAM + disk (12.4 MB delta)</span
        ><br /><br />

        <span class="c"># Everything goes wrong? Roll back instantly</span><br
        />
        <span class="k">$ ign restore</span>
        <span class="s">my-vm</span>
        <span class="f">--from before-deploy</span><br />
        <span class="c">✓ Restored in 48ms — every byte exactly as it was</span>
      </div>
    </div>
  </div>
</section>

