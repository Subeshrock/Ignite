<section class="hero">
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="hero__glow hero__glow--cyan" aria-hidden="true"></div>
  <div class="hero__grid" aria-hidden="true"></div>
  <div class="hero__particles" aria-hidden="true">
    <div class="particle p1"></div>
    <div class="particle p2"></div>
    <div class="particle p3"></div>
    <div class="particle p4"></div>
  </div>

  <div class="wrap hero__wrap">
    <div class="tag tag--cyan">
      <span>🌐</span> Now in v1.1 — Open Source · Apache 2.0
    </div>

    <h1 class="hero__h1">
      Run VMs like containers.<br/>
      <span class="grad">Pervasive as the sky.</span>
    </h1>

    <p class="hero__sub">
      Vyoma is a MicroVM manager powered by <strong>cloud-hypervisor</strong>.
      Use OCI images you already have, get <strong>hardware-level isolation</strong>
      in under 150ms. One binary. No YAML gymnastics.
    </p>

    <div class="hero__install">
      <div class="hero__cmd">
        <span class="hero__prompt">$</span>
        <span>curl -sfL https://get.vyoma.dev | sh</span>
        <button
          class="hero__copy"
          aria-label="Copy install command"
          onclick="navigator.clipboard.writeText('curl -sfL https://get.vyoma.dev | sh')"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2">
            <rect x="9" y="9" width="13" height="13" rx="2"></rect>
            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path>
          </svg>
        </button>
      </div>
    </div>

    <div class="hero__actions">
      <a href="#start" class="btn btn--primary">Get Started →</a>
      <a
        href="https://github.com/VyomaVM/Vyoma"
        target="_blank"
        rel="noopener"
        class="btn btn--ghost"
      >View on GitHub ↗</a>
    </div>

    <div class="hero__stats">
      <div class="hero__stat">
        <strong>&lt;150ms</strong>
        <span>Cold boot</span>
      </div>
      <div class="hero__stat-sep" aria-hidden="true"></div>
      <div class="hero__stat">
        <strong>~5 MB</strong>
        <span>VM overhead</span>
      </div>
      <div class="hero__stat-sep" aria-hidden="true"></div>
      <div class="hero__stat">
        <strong>100%</strong>
        <span>Kernel isolation</span>
      </div>
      <div class="hero__stat-sep" aria-hidden="true"></div>
      <div class="hero__stat">
        <strong>0</strong>
        <span>Config files needed</span>
      </div>
    </div>

    <!-- Terminal demo -->
    <div class="hero__terminal">
      <div class="term__bar">
        <div class="term__dots">
          <span></span><span></span><span></span>
        </div>
        <span class="term__title">terminal — vyoma</span>
      </div>
      <div class="term__body codeblock">
        <span class="c"># Boot an Ubuntu MicroVM via cloud-hypervisor</span><br/>
        <span class="k">$ vyoma run</span>
        <span class="s"> ubuntu:latest</span>
        <span class="f"> --vcpu 2 --memory 512M -p 8080:80</span><br/>
        <span class="c">⚡ VM booted in 118ms — 172.19.0.2</span><br/><br/>

        <span class="c"># Real VM — its own kernel, not namespaces</span><br/>
        <span class="k">$ vyoma exec</span>
        <span class="s"> my-vm</span>
        <span class="f"> uname -r</span><br/>
        <span class="c">6.1.0-vyoma — cloud-hypervisor VMM</span><br/><br/>

        <span class="c"># Snapshot the entire machine state</span><br/>
        <span class="k">$ vyoma snapshot</span>
        <span class="s"> my-vm</span>
        <span class="f"> --name before-deploy</span><br/>
        <span class="c">📸 Snapshot saved: CPU + RAM + disk (11.8 MB delta)</span><br/><br/>

        <span class="c"># Roll back instantly — full fidelity</span><br/>
        <span class="k">$ vyoma restore</span>
        <span class="s"> my-vm</span>
        <span class="f"> --from before-deploy</span><br/>
        <span class="c">✓ Restored in 44ms — every byte exactly as it was</span>
      </div>
    </div>
  </div>
</section>

