<style>
.nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  background:rgba(5,5,7,0.75);
  backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);
  border-bottom:1px solid var(--border);
}
.nav__inner{display:flex;align-items:center;height:60px;gap:2rem}
.nav__logo{display:flex;align-items:center;gap:0.5rem;font-weight:800;font-size:1.15rem}
.nav__logo span{
  background:linear-gradient(135deg,var(--fire-light),var(--fire));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.nav__links{display:flex;gap:1.75rem;margin-left:auto}
.nav__links a{font-size:0.8125rem;font-weight:500;color:var(--text-muted);transition:color 0.2s}
.nav__links a:hover{color:var(--text)}
.nav__right{margin-left:auto}
.btn--sm{padding:0.4rem 0.9rem;font-size:0.8rem;border-radius:8px;gap:0.4rem}
.nav__burger{display:none;flex-direction:column;gap:5px;padding:6px}
.nav__burger span{width:18px;height:1.5px;background:var(--text-dim);border-radius:1px;transition:0.2s}

.mobile-menu{
  display:none;position:fixed;top:60px;left:0;right:0;z-index:99;
  background:var(--bg-raised);border-bottom:1px solid var(--border);
  flex-direction:column;padding:1rem 1.5rem;gap:0.5rem;
}
.mobile-menu a{
  padding:0.75rem 0;font-size:0.9375rem;font-weight:500;color:var(--text-dim);
  border-bottom:1px solid var(--border);
}
.mobile-menu.open{display:flex}

@media(max-width:768px){
  .nav__links,.nav__right{display:none}
  .nav__burger{display:flex}
}
</style>

<script>
document.getElementById('burger')?.addEventListener('click',()=>{
  document.getElementById('mobile-menu')?.classList.toggle('open');
});
document.querySelectorAll('.mobile-menu a').forEach(a=>{
  a.addEventListener('click',()=>{
    document.getElementById('mobile-menu')?.classList.remove('open');
  });
});
</script>
